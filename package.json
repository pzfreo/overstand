{
  "name": "overstand",
  "version": "1.0.0",
  "description": "Instrument neck diagram generator",
  "private": true,
  "bin": {
    "overstand": "bin/overstand"
  },
  "type": "module",
  "scripts": {
    "build:ts": "vite build",
    "dev": "vite",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "npx playwright test",
    "lint": "eslint src-ts/ web/",
    "lint:fix": "eslint src-ts/ web/ --fix",
    "format": "prettier --write 'src-ts/**/*.ts' 'web/**/*.js'",
    "format:check": "prettier --check 'src-ts/**/*.ts' 'web/**/*.js'",
    "cli": "tsx src-ts/cli/cli.ts",
    "build:cli": "bun build src-ts/cli/main.ts --compile --outfile dist/overstand"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.50.0",
    "@types/node": "^25.3.3",
    "@types/pdfkit": "^0.17.5",
    "@types/svg-to-pdfkit": "^0.1.4",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "jsdom": "^26.1.0",
    "prettier": "^3.8.1",
    "serve": "^14.2.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "opentype.js": "^1.3.4",
    "pdfkit": "^0.17.2",
    "svg-to-pdfkit": "^0.1.8"
  }
}
